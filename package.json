{
    "name": "mackeys-configurator",
    "version": "0.0.2",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "gtkx dev src/dev.tsx",
        "build": "gtkx build",
        "typecheck": "tsc --noEmit",
        "start": "node dist/bundle.js",
        "bundle": "gtkx build && tsx scripts/bundle.ts",
        "build:sea": "bash scripts/build-sea.sh",
        "build:appimage": "bash scripts/build-appimage.sh",
        "build:flatpak": "bash scripts/build-flatpak.sh"
    },
    "gtkx": {
        "appId": "com.mackeysconfigurator.app"
    },
    "dependencies": {
        "@gtkx/css": "^0.20.0",
        "@gtkx/ffi": "^0.20.0",
        "@gtkx/react": "^0.20.0",
        "react": "^19.2.4"
    },
    "devDependencies": {
        "@gtkx/cli": "^0.20.0",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "esbuild": "^0.27.4",
        "postject": "1.0.0-alpha.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0"
    }
}
